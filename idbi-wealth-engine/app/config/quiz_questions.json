{
  "version": "v1.0",
  "steps": {
    "step1": {
      "title": "Life Stage & Priorities",
      "description": "Help us understand where you are in your financial journey",
      "questions": {
        "q1": {
          "id": "life_stage",
          "question": "Which of these best describes your current life stage?",
          "type": "single_choice",
          "required": true,
          "options": [
            {
              "value": "starting_career",
              "label": "Starting my career",
              "description": "First job, building savings"
            },
            {
              "value": "building_wealth",
              "label": "Building wealth",
              "description": "Established income, growing family/assets"
            },
            {
              "value": "major_milestones",
              "label": "Preparing for major milestones",
              "description": "Home, marriage, children's education"
            },
            {
              "value": "nearing_retirement",
              "label": "Nearing retirement",
              "description": "Preserving wealth, planning exit from work"
            },
            {
              "value": "retired",
              "label": "Retired",
              "description": "Managing existing wealth, legacy planning"
            }
          ]
        },
        "q2": {
          "id": "priorities",
          "question": "What are your top financial priorities right now?",
          "type": "multiple_choice",
          "required": true,
          "min_selections": 1,
          "max_selections": 3,
          "options": [
            {
              "value": "emergency_fund",
              "label": "Build an emergency fund",
              "icon": "shield"
            },
            {
              "value": "home_purchase",
              "label": "Buy a home / pay off home loan",
              "icon": "home"
            },
            {
              "value": "children_education",
              "label": "Children's education",
              "icon": "graduation-cap"
            },
            {
              "value": "retirement",
              "label": "Retirement planning",
              "icon": "piggy-bank"
            },
            {
              "value": "marriage_self",
              "label": "Marriage (self)",
              "icon": "heart"
            },
            {
              "value": "marriage_children",
              "label": "Marriage (children)",
              "icon": "users"
            },
            {
              "value": "vehicle_purchase",
              "label": "Buy a vehicle",
              "icon": "car"
            },
            {
              "value": "business_startup",
              "label": "Start/grow a business",
              "icon": "briefcase"
            },
            {
              "value": "wealth_growth",
              "label": "Wealth growth (investments)",
              "icon": "trending-up"
            },
            {
              "value": "travel_lifestyle",
              "label": "Travel / lifestyle goals",
              "icon": "plane"
            },
            {
              "value": "tax_saving",
              "label": "Tax saving",
              "icon": "file-text"
            },
            {
              "value": "debt_repayment",
              "label": "Debt repayment",
              "icon": "credit-card"
            }
          ]
        }
      }
    },
    "step2": {
      "title": "Specific Goals",
      "description": "Let's get specific about your priorities",
      "note": "You'll answer these questions for each priority you selected",
      "questions": {
        "q3a": {
          "id": "timeline",
          "question": "When do you plan to achieve this goal?",
          "type": "single_choice",
          "required": true,
          "options": [
            {
              "value": "within_1_year",
              "label": "Within 1 year"
            },
            {
              "value": "1_3_years",
              "label": "1-3 years"
            },
            {
              "value": "3_5_years",
              "label": "3-5 years"
            },
            {
              "value": "5_10_years",
              "label": "5-10 years"
            },
            {
              "value": "10_plus_years",
              "label": "10+ years"
            },
            {
              "value": "ongoing",
              "label": "Ongoing (no fixed deadline)"
            }
          ]
        },
        "q3b": {
          "id": "target_amount",
          "question": "Do you have a target amount in mind?",
          "type": "amount_input",
          "required": false,
          "placeholder": "Enter amount in ₹",
          "note": "Leave blank if you're not sure yet",
          "conditional": {
            "show_if": "timeline != ongoing"
          }
        },
        "q3c": {
          "id": "current_savings",
          "question": "How much have you already saved toward this goal?",
          "type": "single_choice",
          "required": true,
          "options": [
            {
              "value": "nothing",
              "label": "Nothing yet"
            },
            {
              "value": "less_25",
              "label": "Less than 25% of target"
            },
            {
              "value": "25_50",
              "label": "25-50% of target"
            },
            {
              "value": "more_50",
              "label": "More than 50% of target"
            },
            {
              "value": "not_sure",
              "label": "Not sure"
            }
          ]
        }
      }
    },
    "step3": {
      "title": "Risk & Investment Approach",
      "description": "Help us understand your comfort with investment risk",
      "questions": {
        "q4": {
          "id": "investment_preference",
          "question": "If you had ₹10,000 to invest today, which option appeals most to you?",
          "type": "single_choice",
          "required": true,
          "options": [
            {
              "value": "bank_fd",
              "label": "Bank FD",
              "description": "Guaranteed 6-7% returns, zero risk"
            },
            {
              "value": "balanced_mf",
              "label": "Balanced mutual fund",
              "description": "Potential 10-12% returns, moderate risk"
            },
            {
              "value": "equity_mf",
              "label": "Equity mutual fund",
              "description": "Potential 14-16% returns, higher risk"
            },
            {
              "value": "keep_as_savings",
              "label": "Keep as emergency savings, not invest",
              "description": "Maximum safety"
            },
            {
              "value": "need_advice",
              "label": "I'm not sure / I need advice",
              "description": "Help me decide"
            }
          ]
        },
        "q5": {
          "id": "volatility_tolerance",
          "question": "Imagine your investments drop 15% in value temporarily. What would you do?",
          "type": "single_choice",
          "required": true,
          "options": [
            {
              "value": "panic_withdraw",
              "label": "Panic and withdraw everything immediately"
            },
            {
              "value": "uncomfortable_wait",
              "label": "Feel uncomfortable but wait it out"
            },
            {
              "value": "stay_calm",
              "label": "Stay calm — I know markets recover over time"
            },
            {
              "value": "buying_opportunity",
              "label": "See it as a buying opportunity and invest more"
            },
            {
              "value": "wont_invest",
              "label": "I wouldn't invest in anything that could drop 15%"
            }
          ]
        }
      }
    }
  }
}
