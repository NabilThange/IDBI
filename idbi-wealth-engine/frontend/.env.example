# Frontend environment variables (Vite, injected at build time)
# Copy this file to `.env` for local dev. `.env` is gitignored — never commit a real key.

# API key sent to the backend as the `X-API-Key` header on every request.
# Must match the backend's API_KEY. When the backend has no API_KEY set,
# its gate is open, so this can be left blank for local dev.
VITE_API_KEY=

# Backend URL. Leave blank for local dev so requests hit the same origin and
# Vite's dev proxy forwards /api to http://localhost:8000.
# In production set this to the Render backend URL.
VITE_API_URL=
